// MARK: - SlashCommandManagerView
"Imported %lld custom commands." = "已导入 %lld 条自定义命令。";
"A command with this name already exists." = "已存在同名的命令。";
"Restore modified default commands to their original state" = "将已修改的默认命令恢复到原始状态";
