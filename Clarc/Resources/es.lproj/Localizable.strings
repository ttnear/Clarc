// MARK: - Permission Mode Descriptions
"perm.desc.default" = "Pide confirmación antes de cada edición de archivo o comando de shell. Ideal para trabajo sensible o para empezar.";
"perm.desc.acceptEdits" = "Aprueba automáticamente las ediciones de archivos y los comandos comunes del sistema de archivos (mkdir, touch, mv, cp). Sigue pidiendo confirmación para otros comandos de shell.";
"perm.desc.plan" = "Modo de solo lectura. Claude investiga y propone un plan sin hacer cambios. Para el resto de acciones aplica las mismas confirmaciones que el modo predeterminado.";
"perm.desc.auto" = "Se ejecuta sin confirmaciones de permiso. Un clasificador en segundo plano revisa la seguridad de cada acción antes de ejecutarla.";
"perm.desc.bypassPermissions" = "Omite todas las comprobaciones de permisos y mecanismos de seguridad. Úsalo solo en contenedores o máquinas virtuales aislados y sin acceso a internet.";

// MARK: - Effort Level Descriptions
